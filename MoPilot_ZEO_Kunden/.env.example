# ZEO Kundenassistent – Umgebungsvariablen
# Kopieren zu .env und Werte anpassen

# Anthropic API Key (PFLICHT)
ANTHROPIC_API_KEY=sk-ant-...

# Claude-Modell
CLAUDE_MODEL=claude-sonnet-4-6

# Frontend-Backend-URL (wie das Frontend den Backend erreicht)
# Lokal: http://localhost:8000
# Produktion: https://api.zeo-kunden.mopilot.website
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# CORS-Origins (Komma-getrennt)
CORS_ORIGINS=https://zeo-kunden.mopilot.website,http://localhost:3000

# Umgebung
ENVIRONMENT=production
