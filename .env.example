# MoPilot Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://mopilot:YOUR_DB_PASSWORD@postgres:5432/mopilot
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Anthropic API (Claude)
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY

# JWT Secret
SECRET_KEY=YOUR_JWT_SECRET

# CORS
CORS_ORIGINS=https://mopilot.website,https://api.mopilot.website

# Environment
ENVIRONMENT=production
